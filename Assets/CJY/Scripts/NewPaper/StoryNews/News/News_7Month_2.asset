  m_Script: {fileID: 11500000, guid: fe6ee89c1483430429077faf1e0c2c23, type: 3}
  m_Name: News_7Month_2
  m_EditorClassIdentifier: 
  targetMonth: 7
  title: "\uC2E4\uC885 \uC544\uB3D9\uC740 '\uB0A8\uC758 \uC77C'\uC778\uAC00, \uB05D\uC740
    \uC5B4\uB514"
  content: "\uCD5C\uADFC \uAD6C\uB8E1\uCC44\uC131 \uC77C\uB300\uC5D0\uC11C \uC544\uB3D9\uC758
    \uD589\uBC29\uC744 \uBB3B\uB294 \uC2E0\uACE0\uAC00 \uC787\uB530\uB77C \uC811\uC218\uB418\uACE0
    \uC788\uB294 \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4. \uC678\uACFD\uACFC
    \uBC00\uC9D1 \uAC70\uC8FC \uAD6C\uC5ED\uC744 \uC911\uC2EC\uC73C\uB85C \uAD00\uB828
    \uBB38\uC758\uAC00 \uB298\uACE0 \uC788\uB2E4\uB294 \uC124\uBA85\uC774\uB2E4.\r\n\uAD00\uACC4
    \uB2F9\uAD6D\uC740 \u201C\uC0AC\uC548\uC744 \uC5C4\uC911\uD788 \uBCF4\uACE0 \uC788\uB2E4\u201D\uBA70
    \uC0C1\uD669\uC744 \uC608\uC758\uC8FC\uC2DC\uD558\uACE0 \uC788\uB2E4\uB294 \uC785\uC7A5\uC744
    \uBC1D\uD614\uB2E4. \uB2E4\uB9CC \uD604\uC7AC\uAE4C\uC9C0 \uBCC4\uB3C4\uC758
    \uD2B9\uBCC4 \uC870\uCE58\uB098 \uAD6C\uCCB4\uC801 \uB300\uC751 \uACC4\uD68D\uC5D0
    \uB300\uD574\uC11C\uB294 \uC5B8\uAE09\uD558\uC9C0 \uC54A\uC558\uB2E4.\r\n\uC2E0\uACE0
    \uACBD\uC704\uC758 \uACF5\uD1B5\uC810\uACFC \uBC1C\uC0DD \uBC30\uACBD\uC5D0 \uB300\uD574\uC11C\uB294
    \u201C\uB2E4\uAC01\uB3C4\uB85C \uAC80\uD1A0 \uC911\u201D\uC774\uB77C\uB294 \uC124\uBA85\uC774
    \uBC18\uBCF5\uB418\uACE0 \uC788\uC73C\uBA70, \uD2B9\uC815 \uBC94\uC8C4\uC640\uC758
    \uC5F0\uAD00 \uC5EC\uBD80 \uC5ED\uC2DC \uACF5\uC2DD \uD655\uC778\uB41C \uBC14
    \uC5C6\uB2E4\uACE0 \uC804\uD588\uB2E4.\r\n\uC77C\uBD80 \uD559\uAD50\uC640 \uC791\uC5C5\uC7A5\uC5D0\uC11C\uB294
    \uC790\uCCB4 \uD310\uB2E8\uC5D0 \uB530\uB77C \uADC0\uAC00 \uB3D9\uD589\uACFC
    \uCD9C\uC785 \uAD00\uB9AC \uC808\uCC28\uB97C \uAC15\uD654\uD55C \uAC83\uC73C\uB85C
    \uC54C\uB824\uC84C\uB2E4. \uC9C0\uC5ED \uC0AC\uD68C\uC5D0\uC11C\uB294 \uC6B0\uB824\uC758
    \uBAA9\uC18C\uB9AC\uAC00 \uC774\uC5B4\uC9C0\uACE0 \uC788\uC73C\uB098, \uC815\uD655\uD55C
    \uADDC\uBAA8\uC640 \uC6D0\uC778\uC740 \uCD94\uAC00 \uBC1C\uD45C\uB97C \uD1B5\uD574
    \uC815\uB9AC\uB420 \uC608\uC815\uC774\uB77C\uACE0\uB9CC \uBC1D\uD614\uB2E4.\r\n\uB2F9\uAD6D\uC740
    \uD655\uC778\uB418\uC9C0 \uC54A\uC740 \uB0B4\uC6A9\uC758 \uD655\uC0B0\uC744 \uC790\uC81C\uD574
    \uC904 \uAC83\uC744 \uC694\uCCAD\uD588\uB2E4.\r"
  icon: {fileID: 260355830, guid: cd2d5cb1b2e04764881783f8fc40d2ca, type: 3}
