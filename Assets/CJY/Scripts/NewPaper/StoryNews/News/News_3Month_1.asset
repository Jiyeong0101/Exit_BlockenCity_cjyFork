  m_Script: {fileID: 11500000, guid: fe6ee89c1483430429077faf1e0c2c23, type: 3}
  m_Name: News_3Month_1
  m_EditorClassIdentifier: 
  targetMonth: 3
  title: "\uAD6C\uB8E1\uCC44\uC131 \uAE30\uCE68 \uC18C\uB9AC, \uCF5C\uB85D\uB300\uBA70
    '\uB3C4\uC640\uB2EC\uB77C'?"
  content: "\uCD5C\uADFC \uAD6C\uB8E1\uCC44\uC131 \uB0B4\uBD80 \uC77C\uBD80 \uBC00\uC9D1
    \uAD6C\uC5ED\uC5D0\uC11C \uBC1C\uC5F4\uACFC \uAE30\uCE68\uC744 \uD638\uC18C\uD558\uB294
    \uC0AC\uB840\uAC00 \uC774\uC5B4\uC9C0\uACE0 \uC788\uB294 \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4.
    \uBB34\uAE30\uB825 \uC99D\uC138\uB97C \uBCF4\uC774\uB294 \uC774\uB4E4\uB3C4 \uC801\uC9C0
    \uC54A\uC740 \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4. \uC815\uD655\uD55C
    \uC6D0\uC778\uC5D0 \uB300\uD574\uC11C\uB294 \uD655\uC778\uC774 \uC774\uB8E8\uC5B4\uC9C0\uC9C0
    \uC54A\uACE0 \uC788\uB2E4.\r\n\uACF5\uB3D9 \uC6B0\uBB3C\uACFC \uACF5\uC6A9 \uCDE8\uC0AC
    \uC2DC\uC124\uC744 \uC911\uC2EC\uC73C\uB85C \uC790\uC728\uC801 \uC704\uC0DD \uC815\uBE44\uAC00
    \uC774\uB8E8\uC5B4\uC9C0\uACE0 \uC788\uC73C\uBA70, \uC77C\uBD80 \uACE8\uBAA9\uC5D0\uC11C\uB294
    \uD1B5\uD589\uC774 \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC904\uC5B4\uB4E0 \uBAA8\uC2B5\uC774\uB2E4.
    \uD2B9\uC815 \uAD6C\uAC04\uC5D0\uC11C\uB294 \uC774\uB3D9 \uD655\uC778\uC774 \uBCF4\uB2E4
    \uC5C4\uACA9\uD788 \uC774\uB8E8\uC5B4\uC9C0\uACE0 \uC788\uB294 \uAC83\uC73C\uB85C
    \uC804\uD574\uC84C\uB2E4.\r\n\uAD00\uACC4 \uCE21\uC740 \uACFC\uB3C4\uD55C \uCD94\uCE21\uC740
    \uC790\uC81C\uD560 \uD544\uC694\uAC00 \uC788\uB2E4\uACE0 \uBC1D\uD788\uBA70,
    \uC0C1\uD669\uC744 \uC608\uC758\uC8FC\uC2DC\uD558\uACE0 \uC788\uB2E4\uB294 \uC785\uC7A5\uC744
    \uC804\uD588\uB2E4. \uBCD1\uBA85\uACFC \uBC1C\uC0DD \uACBD\uB85C\uC5D0 \uB300\uD574\uC11C\uB294
    \uC544\uC9C1 \uBA85\uD655\uD788 \uC815\uB9AC\uB418\uC9C0 \uC54A\uC740 \uC0C1\uD0DC\uB2E4.\r\n\uC0C1\uAD8C\uACFC
    \uC791\uC5C5\uC7A5 \uC77C\uBD80\uC5D0\uC11C\uB294 \uC6B4\uC601 \uC2DC\uAC04\uC774
    \uB2E8\uCD95\uB418\uACE0 \uC788\uC73C\uBA70, \uC57C\uAC04 \uC655\uB798\uB3C4
    \uC774\uC804\uBCF4\uB2E4 \uB738\uD574\uC9C4 \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4.\r\n\uAD6C\uB8E1\uCC44\uC131
    \uB0B4\uBD80\uC758 \uACF5\uAE30\uC5D0\uB294 \uC774\uC804\uACFC \uB2E4\uB978 \uAE30\uC0C9\uC774
    \uAC10\uB3CC\uACE0 \uC788\uB2E4. \uD5A5\uD6C4 \uCD94\uC774\uB294 \uCD94\uAC00
    \uD655\uC778\uC744 \uAC70\uCCD0 \uC804\uD574\uC9C8 \uC608\uC815\uC774\uB2E4.\r"
  icon: {fileID: 260355830, guid: cd2d5cb1b2e04764881783f8fc40d2ca, type: 3}
