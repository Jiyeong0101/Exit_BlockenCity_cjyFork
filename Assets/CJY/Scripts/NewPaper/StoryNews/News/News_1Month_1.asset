  m_Script: {fileID: 11500000, guid: fe6ee89c1483430429077faf1e0c2c23, type: 3}
  m_Name: News_1Month_1
  m_EditorClassIdentifier: 
  targetMonth: 1
  title: "\uCE58\uC548\uB300 \uBCF4\uACE0 \uB180\uB780 \uAC00\uC2B4? \uC8C4 \uC5C6\uB2E4\uBA74
    \uB2F9\uB2F9"
  content: "\uCD5C\uADFC \uAD6C\uB8E1\uCC44\uC131 \uC678\uACFD \uC77C\uB300\uC5D0
    \uCE58\uC548 \uC778\uB825\uC774 \uCD94\uAC00 \uBC30\uCE58\uB41C \uAC83\uC73C\uB85C
    \uD655\uC778\uB418\uC5C8\uB2E4.\r\n\uC8FC\uC694 \uCD9C\uC785\uB85C\uC640 \uBB3C\uC790
    \uC9D1\uC0B0\uC9C0, \uC57C\uAC04 \uD1B5\uD589\uC774 \uC7A6\uC740 \uAD6C\uAC04\uC744
    \uC911\uC2EC\uC73C\uB85C \uC21C\uCC30\uC774 \uD655\uB300\uB41C \uBAA8\uC2B5\uC774\uB2E4.\r\n\uAD00\uACC4
    \uB2F9\uAD6D\uC740 \uC774\uBC88 \uC870\uCE58\uC5D0 \uB300\uD574 \uC608\uBC29\uC801
    \uCC28\uC6D0\uC758 \uC9C8\uC11C \uD655\uB9BD\uC774\uB77C\uACE0 \uC124\uBA85\uD558\uC600\uB2E4.
    \uD2B9\uC815 \uB300\uC0C1\uC744 \uC0C1\uC815\uD55C \uC870\uCE58\uB294 \uC544\uB2C8\uBA70,
    \uC8FC\uBBFC \uC548\uC804 \uD655\uBCF4\uB97C \uC704\uD55C \uC77C\uBC18\uC801
    \uCE58\uC548 \uBCF4\uAC15\uC774\uB77C\uB294 \uC785\uC7A5\uC774\uB2E4.\r\n\uC77C\uBD80
    \uAD6C\uAC04\uC5D0\uC11C\uB294 \uAC80\uBB38 \uBC0F \uD1B5\uD589 \uD655\uC778
    \uC808\uCC28\uAC00 \uBCF4\uAC15\uB41C \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4.
    \uC678\uACFD \uC9C0\uC5ED\uC5D0\uC11C \uBCF4\uACE0\uB41C \uBE44\uC778\uAC00 \uBB3C\uC790
    \uC774\uB3D9\uACFC \uAD00\uB828\uD558\uC5EC \uC0AC\uC2E4 \uAD00\uACC4 \uD655\uC778\uC774
    \uC774\uB8E8\uC5B4\uC9C0\uACE0 \uC788\uB294 \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.
    \uB2E4\uB9CC \uAD6C\uCCB4\uC801\uC778 \uACBD\uC704\uC5D0 \uB300\uD574\uC11C\uB294
    \uBA85\uD655\uD55C \uACB0\uB860\uC5D0 \uC774\uB974\uAE30\uAE4C\uC9C0 \uC2DC\uAC04\uC774
    \uD544\uC694\uD560 \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4.\r\n\uC0C1\uC778\uB4E4
    \uC0AC\uC774\uC5D0\uC11C\uB294 \u201C\uC57C\uAC04 \uBD84\uC704\uAE30\uAC00 \uC815\uB3C8\uB41C
    \uB4EF\uD558\uB2E4\u201D\uB294 \uBC18\uC751\uC774 \uB098\uC654\uC73C\uBA70, \uC8FC\uBBFC\uB4E4
    \uB610\uD55C \u201C\uC774\uC804\uBCF4\uB2E4 \uD55C\uCE35 \uC870\uC6A9\uD574\uC84C\uB2E4\u201D\uACE0
    \uC804\uD588\uB2E4.\r\n\uCE58\uC548 \uC778\uB825 \uC99D\uAC15 \uC870\uCE58\uB294
    \uB2F9\uBD84\uAC04 \uC720\uC9C0\uB420 \uC804\uB9DD\uC774\uB2E4.\r\n\uC678\uACFD\uC758
    \uC57C\uAC04 \uC9C8\uC11C\uB294 \uC810\uCC28 \uC815\uBE44\uB418\uC5B4 \uAC00\uB294
    \uC911\uC774\uB2E4."
  icon: {fileID: 260355830, guid: cd2d5cb1b2e04764881783f8fc40d2ca, type: 3}
