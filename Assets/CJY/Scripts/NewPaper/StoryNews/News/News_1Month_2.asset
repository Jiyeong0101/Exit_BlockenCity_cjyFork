  m_Script: {fileID: 11500000, guid: fe6ee89c1483430429077faf1e0c2c23, type: 3}
  m_Name: News_1Month_2
  m_EditorClassIdentifier: 
  targetMonth: 1
  title: "\uC2E0\uC784 \uAD00\uB9AC\uC790, \uBE44\uC815\uC0C1\uC758 \uC815\uC0C1\uD654
    \uC608\uACE0"
  content: "\uCD5C\uADFC \uAD6C\uB8E1\uCC44\uC131 \uC804\uC5ED\uC744 \uAD00\uD560\uD560
    \uC2E0\uC784 \uAC74\uBB3C \uAD00\uB9AC \uB2F4\uB2F9\uC790\uAC00 \uBD80\uC784\uD558\uC600\uB2E4.\r\n\uADF8\uAC04
    \uC9C0\uC801\uB418\uC5B4 \uC628 \uAD00\uB9AC \uACF5\uBC31\uACFC \uC2DC\uC124
    \uB178\uD6C4 \uBB38\uC81C\uB97C \uBCF4\uC644\uD558\uAE30 \uC704\uD55C \uC870\uCE58\uB85C
    \uC804\uD574\uC84C\uB2E4.\r\n\uC2E0\uC784 \uB2F4\uB2F9\uC790\uB294 \uC678\uACFD
    \uBC0F \uC911\uC2EC \uAD6C\uC5ED\uC758 \uC784\uB300 \uD604\uD669\uACFC \uAD6C\uC870
    \uC548\uC804 \uC0C1\uD0DC\uB97C \uC6B0\uC120\uC801\uC73C\uB85C \uD655\uC778\uD560
    \uACC4\uD68D\uC778 \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4. \uBB34\uB2E8
    \uC99D\uCD95 \uBC0F \uBBF8\uB4F1\uB85D \uC810\uC720 \uC2E4\uD0DC \uB610\uD55C
    \uC810\uAC80 \uB300\uC0C1\uC5D0 \uD3EC\uD568\uB41C \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4.
    \uC77C\uBD80 \uAD6C\uC5ED\uC5D0\uC11C\uB294 \uC774\uBBF8 \uD604\uC7A5 \uD655\uC778
    \uC808\uCC28\uAC00 \uC774\uB8E8\uC5B4\uC9C0\uACE0 \uC788\uB2E4.\r\n\uAD00\uACC4
    \uCE21\uC740 \uC7A5\uAE30\uC801 \uC815\uBE44 \uCCB4\uACC4 \uB9C8\uB828\uC774
    \uBAA9\uC801\uC774\uB77C\uACE0 \uBC1D\uD614\uB2E4. \uBD88\uBC95 \uAC1C\uC870
    \uBB38\uC81C \uB4F1\uC5D0 \uB300\uD574\uC11C\uB3C4 \uB2E8\uACC4\uC801 \uC870\uCE58\uAC00
    \uAC80\uD1A0\uB418\uACE0 \uC788\uB294 \uAC83\uC73C\uB85C \uC54C\uB824\uC84C\uB2E4.
    \uAD6C\uCCB4\uC801 \uC2DC\uD589 \uBC94\uC704\uC5D0 \uB300\uD574\uC11C\uB294 \uCD94\uD6C4
    \uC815\uB9AC\uB420 \uC804\uB9DD\uC774\uB2E4.\r\n\uC0C1\uC778\uB4E4\uACFC \uC784\uCC28\uC778\uB4E4
    \uC0AC\uC774\uC5D0\uC11C\uB294 \uB2E4\uC591\uD55C \uC758\uACAC\uC774 \uB098\uC624\uACE0
    \uC788\uB2E4. \uAD00\uB9AC \uAE30\uC900\uC774 \uBA85\uD655\uD574\uC9C8 \uACBD\uC6B0
    \uAC70\uB798 \uC9C8\uC11C\uAC00 \uC548\uC815\uB420 \uC218 \uC788\uB2E4\uB294
    \uACAC\uD574\uC640 \uD568\uAED8, \uC810\uAC80 \uAC15\uD654\uC5D0 \uB530\uB978
    \uBD80\uB2F4\uC744 \uC6B0\uB824\uD558\uB294 \uBAA9\uC18C\uB9AC\uB3C4 \uC804\uD574\uC84C\uB2E4.\r\n\uAD6C\uB8E1\uCC44\uC131
    \uAD00\uB9AC \uCCB4\uACC4\uB294 \uC810\uC9C4\uC801\uC778 \uC815\uBE44 \uC808\uCC28\uC5D0
    \uB4E4\uC5B4\uAC04 \uAC83\uC73C\uB85C \uBCF4\uC778\uB2E4.\r"
  icon: {fileID: 260355830, guid: cd2d5cb1b2e04764881783f8fc40d2ca, type: 3}
