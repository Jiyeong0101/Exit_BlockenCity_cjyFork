--- !u!114 &1035180509438569759
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4211319903626768358}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\uCD5C\uADFC \uB0B4\uC804 \uCD94\uBAA8\uC77C\uC744 \uB9DE\uC544 \uB3C4\uC2EC
    \uC804\uC5ED\uC5D0\uC11C \uBB35\uB150 \uD589\uC0AC\uAC00 \uC9C4\uD589\uB418\uC5C8\uB2E4.
    \uAD00\uACF5\uC11C\uC640 \uC8FC\uC694 \uAE30\uAD00\uC5D0\uB294 \uC870\uAE30\uAC00
    \uAC8C\uC591\uB418\uC5C8\uC73C\uBA70, \uC77C\uC815 \uC2DC\uAC04 \uC0AC\uC774\uB80C\uC774
    \uC6B8\uB838\uB2E4.\r\n\n\uAD00\uACC4 \uCE21\uC740 \uAD6D\uAC00\uC801 \uC544\uD514\uC744
    \uB418\uC0C8\uAE30\uB294 \uB0A0\uC774\uB77C\uACE0 \uBC1D\uD614\uB2E4. \uAE30\uB150\uC2DD\uC740
    \uC5C4\uC219\uD55C \uBD84\uC704\uAE30 \uC18D\uC5D0\uC11C \uC774\uB8E8\uC5B4\uC84C\uC73C\uBA70,
    \uCC38\uC804 \uC720\uAC00\uC871\uACFC \uAD00\uACC4 \uC778\uC0AC\uB4E4\uC774 \uCC38\uC11D\uD55C
    \uAC83\uC73C\uB85C \uC804\uD574\uC84C\uB2E4.\r\n\n\uB3C4\uC2EC \uC77C\uBD80 \uAC70\uB9AC\uC5D0\uC11C\uB294
    \uC2DC\uBBFC\uB4E4\uC774 \uC790\uBC1C\uC801\uC73C\uB85C \uBB35\uB150\uD558\uBA70
    \uD589\uC0AC\uB97C \uC9C0\uCF1C\uBCF4\uB294 \uBAA8\uC2B5\uC774 \uAD00\uCC30\uB418\uC5C8\uC73C\uBA70,
    \uC77C\uBD80 \uC0C1\uAD8C\uC5D0\uC11C\uB294 \uC77C\uC815 \uC2DC\uAC04 \uC601\uC5C5\uC744
    \uC870\uC815\uD558\uB294 \uC6C0\uC9C1\uC784\uB3C4 \uB098\uD0C0\uB0AC\uB2E4. \uD3C9\uC18C\uC640
    \uB2E4\uB978 \uACE0\uC694\uD568\uC774 \uAE43\uB4E0 \uAC00\uC6B4\uB370, \uD589\uC778\uB4E4\uC740
    \uBB35\uBB35\uD788 \uC21C\uAC04\uC744 \uC9C0\uCF1C\uBCF4\uB294 \uBD84\uC704\uAE30\uC600\uB2E4.\r\n\n\uB0B4\uC804\uC758
    \uC0C1\uD754\uC740 \uC0AC\uD68C \uC5EC\uB7EC \uC9C0\uC810\uC5D0 \uBBF8\uBB18\uD558\uAC8C
    \uB0A8\uC544 \uC788\uB294 \uAC83\uC73C\uB85C \uC804\uD574\uC9C4\uB2E4. \uCD94\uBAA8\uC77C
    \uD589\uC0AC\uB294 \uAC89\uC73C\uB85C\uB294 \uC870\uC6A9\uD558\uC9C0\uB9CC, \uB0B4\uBA74\uC5D0\uB294
    \uC5EC\uC804\uD788 \uBB35\uC911\uD55C \uCE68\uBB35\uACFC \uBB34\uAC8C \uC788\uB294
    \uAE30\uC5B5\uC774 \uD750\uB974\uB294 \uB0A0\uB85C \uAE30\uB85D\uB418\uC5C8\uB2E4.
    \uACF5\uC2DD \uC808\uCC28 \uC18D\uC5D0 \uC2DC\uBBFC \uAC01\uC790\uC758 \uB9C8\uC74C
    \uC18D\uC5D0\uB3C4 \uB418\uC0C8\uACA8\uC9C0\uB294 \uC758\uBBF8\uAC00 \uC788\uB2E4\uB294
    \uD3C9\uAC00\uAC00 \uB098\uC628\uB2E4."
  m_isRightToLeft: 0
